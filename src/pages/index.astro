---
import Layout from '../layouts/Layout.astro';
import molecule from '../assets/molecule.png';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const pillClass: Record<string, string> = {
  'story': 'pill--teal',
  'tools': 'pill--orange',
  'brain science': 'pill--purple',
};
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container--wide">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="kicker">from imagination to execution</span>
          <h1>big ideas. better tools.</h1>
          <p>I have more ideas than most people know what to do with. For a long time, fighting my own cognition meant most of them stayed stuck in my head. This is what it looks like when they finally get out.</p>
          <a href="/blog/the-catalyst" class="btn-primary">start here</a>
        </div>
        <div class="hero-image">
          <img src={molecule.src} alt="" class="molecule-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Posts -->
  <section class="posts-section">
    <div class="container--wide">
      <div class="section-header">
        <h2>Recent stories</h2>
        <a href="/blog">all posts →</a>
      </div>
      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <span class={`pill ${pillClass[post.data.type] ?? 'pill--teal'}`}>{post.data.type}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description ?? post.data.excerpt}</p>
            <span class="meta">{post.data.date}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
/* Hero */
.hero {
  padding: 1.5rem 0;
  margin-top: 0;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
  min-height: 85vh;
  display: flex;
  align-items: center;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
  width: 100%;
}
.kicker {
  display: inline-block;
  background: var(--teal-light);
  color: var(--teal-dark);
  font-size: 0.8rem;
  font-weight: 500;
  padding: 0.3rem 0.9rem;
  border-radius: 20px;
  margin-top: 0;
  margin-bottom: 1.25rem;
  letter-spacing: 0.02em;
}
.hero-text h1 {
  font-size: 3.5rem;
  margin-bottom: 1rem;
}
.hero-text p {
  color: var(--text-muted);
  font-size: 1.05rem;
  margin-bottom: 1.75rem;
}
.btn-primary {
  display: inline-block;
  background: var(--teal);
  color: var(--white);
  padding: 0.65rem 1.5rem;
  border-radius: 24px;
  font-weight: 500;
  font-size: 0.95rem;
  text-decoration: none;
}
.hero-image {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
.molecule-img {
  width: 85%;
  max-width: none;
  height: auto;
  display: block;
}

/* Pills */
.pill {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 500;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  margin-bottom: 0.75rem;
}
.pill--purple { background: var(--purple-light); color: var(--purple-dark); }
.pill--teal   { background: var(--teal-light);   color: var(--teal-dark);   }
.pill--orange { background: var(--orange-light);  color: var(--orange-dark); }

/* Posts section */
.posts-section { padding: 3rem 0; }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.section-header h2 { font-size: 1.25rem; }
.section-header a  { font-size: 0.85rem; color: var(--teal-dark); }
.post-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.25rem;
}
.post-card {
  display: block;
  text-decoration: none;
  color: inherit;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.5rem;
}
.post-card h3 {
  font-size: 1rem;
  margin-bottom: 0.6rem;
  line-height: 1.4;
}
.post-card p {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
}
.meta {
  font-size: 0.8rem;
  color: var(--text-muted);
}

@media (max-width: 640px) {
  .hero {
    min-height: unset;
    padding: 2.5rem 0;
  }
  .hero-inner {
    grid-template-columns: 1fr;
  }
  .hero-image {
    display: none;
  }
  .hero-text h1 {
    font-size: 2.25rem;
  }
  .post-grid {
    grid-template-columns: 1fr;
  }
}
</style>