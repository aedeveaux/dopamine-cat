---
const { label = "the problem" } = Astro.props;
---
<div class="problem-card">
  <span class="block-label">{label}</span>
  <slot />
</div>

<style>
.problem-card {
  border-left: 3px solid var(--teal);
  background: var(--teal-light);
  padding: 1.25rem 1.5rem;
  margin: 2rem 0;
}
.block-label {
  display: block;
  font-size: 0.7rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--teal-dark);
  margin-bottom: 0.6rem;
}
.problem-card :global(p) {
  font-family: 'Nunito', sans-serif;
  font-size: 1.05rem;
  color: var(--teal-dark);
  line-height: 1.75;
  margin: 0;
}
</style>