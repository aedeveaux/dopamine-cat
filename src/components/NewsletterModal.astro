---
import molecule from '../assets/molecule.png';
import NewsletterSignup from './NewsletterSignup.astro';
---

<dialog
  class="newsletter-modal"
  aria-labelledby="newsletter-modal-title"
  data-newsletter-modal
>
  <div class="newsletter-modal__panel">
    <div class="newsletter-modal__visual" aria-hidden="true">
      <div class="newsletter-modal__visual-shell">
        <img src={molecule.src} alt="" class="newsletter-modal__image" />
      </div>
    </div>

    <div class="newsletter-modal__content">
      <button
        type="button"
        class="newsletter-modal__close"
        aria-label="Close newsletter signup"
        data-newsletter-close
      >
        ×
      </button>

      <div class="newsletter-modal__content-inner">
        <NewsletterSignup
          compact={true}
          framed={false}
          headingTag="h2"
          headingId="newsletter-modal-title"
          idPrefix="modal"
          title="Stay in the loop"
          description="New stories when my brain produces them — irregularly but enthusiastically. No spam, no ads, no nonsense."
          emailPlaceholder="Your email"
          buttonLabel="Join the list"
          helperText="Unsubscribe anytime."
        />
      </div>
    </div>
  </div>
</dialog>

<script>
  const modal = document.querySelector('[data-newsletter-modal]');
  if (modal instanceof HTMLDialogElement) {
    let lastTrigger = null;

    const focusInput = () => {
      const input = modal.querySelector('input[type="email"]');
      if (input instanceof HTMLElement) {
        input.focus();
      }
    };

    const openModal = (trigger) => {
      lastTrigger = trigger instanceof HTMLElement ? trigger : null;
      if (!modal.open) {
        modal.showModal();
      }
      requestAnimationFrame(focusInput);
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const trigger = target.closest('[data-newsletter-trigger]');
      if (trigger instanceof HTMLAnchorElement) {
        event.preventDefault();
        openModal(trigger);
        return;
      }

      if (target.closest('[data-newsletter-close]')) {
        modal.close();
      }
    });

    modal.addEventListener('click', (event) => {
      if (event.target === modal) {
        modal.close();
      }
    });

    modal.addEventListener('close', () => {
      if (lastTrigger instanceof HTMLElement) {
        lastTrigger.focus();
      }
    });
  }
</script>

<style>
.newsletter-modal {
  width: auto;
  max-width: none;
  max-height: none;
  border: none;
  padding: 28px;
  background: transparent;
  margin: auto;
  inset: 0;
  overflow: visible;
}

.newsletter-modal[open] {
  display: grid;
  place-items: center;
}

.newsletter-modal::backdrop {
  background: rgba(16, 18, 22, 0.46);
  backdrop-filter: blur(5px);
}

.newsletter-modal__panel {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  width: min(980px, calc(100vw - 56px));
  position: relative;
  overflow: hidden;
  min-height: min(620px, calc(100vh - 56px));
  max-height: calc(100vh - 56px);
  border: 1px solid rgba(129, 21, 211, 0.08);
  border-radius: 28px;
  background: #fcfbf8;
  box-shadow: 0 28px 90px rgba(12, 14, 18, 0.2);
}

.newsletter-modal__visual {
  display: flex;
  min-height: 100%;
  padding: 28px;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.88), transparent 40%),
    linear-gradient(160deg, #f4f8ff 0%, #eefaf8 48%, #fbf3ff 100%);
}

.newsletter-modal__visual-shell {
  width: 100%;
  min-height: 100%;
  border-radius: 22px;
  padding: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 30% 20%, rgba(255, 255, 255, 0.92), transparent 24%),
    radial-gradient(circle at 68% 72%, rgba(129, 21, 211, 0.08), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.4));
  border: 1px solid rgba(255, 255, 255, 0.78);
}

.newsletter-modal__image {
  width: min(100%, 380px);
  max-height: min(460px, 54vh);
  object-fit: contain;
  object-position: center;
}

.newsletter-modal__content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 44px;
  background: linear-gradient(180deg, rgba(252, 251, 248, 0.98), rgba(255, 255, 255, 0.92));
}

.newsletter-modal__content-inner {
  width: min(100%, 390px);
}

.newsletter-modal__close {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(26, 26, 26, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.88);
  color: var(--text-muted);
  font: inherit;
  font-size: 1.2rem;
  line-height: 1;
  cursor: pointer;
  backdrop-filter: blur(8px);
}

.newsletter-modal__close:hover {
  background: var(--white);
}

.newsletter-modal__close:focus {
  outline: 2px solid color-mix(in srgb, var(--purple) 40%, white);
  outline-offset: 2px;
}

@media (max-width: 640px) {
  .newsletter-modal {
    padding: 12px;
  }

  .newsletter-modal__panel {
    width: min(calc(100vw - 24px), 34rem);
    grid-template-columns: 1fr;
    min-height: auto;
    max-height: calc(100vh - 24px);
    border-radius: 24px;
    overflow-y: auto;
  }

  .newsletter-modal__visual {
    padding: 16px 16px 0;
  }

  .newsletter-modal__visual-shell {
    min-height: 220px;
    padding: 1.5rem;
  }

  .newsletter-modal__content {
    padding: 28px 24px 24px;
  }

  .newsletter-modal__close {
    top: 16px;
    right: 16px;
  }
}
</style>
