---
const { label = "the conversation" } = Astro.props;
---
<div class="ai-chat">
  <span class="block-label">{label}</span>
  <slot />
</div>

<style>
.ai-chat {
  background: #f7f7f7;
  border-radius: 16px;
  padding: 1.5rem;
  margin: 2rem 0;
}
.block-label {
  display: block;
  font-size: 0.7rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}
.ai-chat :global(.bubble) {
  display: flex;
  gap: 10px;
  margin-bottom: 1rem;
  align-items: flex-start;
}
.ai-chat :global(.bubble:last-child) { margin-bottom: 0; }
.ai-chat :global(.bubble.me) { flex-direction: row-reverse; }
.ai-chat :global(.avatar) {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 500;
  flex-shrink: 0;
}
.ai-chat :global(.bubble .avatar) {
  background: var(--purple-light);
  color: var(--purple-dark);
}
.ai-chat :global(.bubble.me .avatar) {
  background: var(--teal-light);
  color: var(--teal-dark);
}
.ai-chat :global(.text) {
  background: white;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 0.75rem 1rem;
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text);
  max-width: 82%;
}
.ai-chat :global(.bubble.me .text) {
  background: var(--teal-light);
  border-color: transparent;
  color: var(--teal-dark);
}
</style>