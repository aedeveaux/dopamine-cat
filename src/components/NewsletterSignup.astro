---
interface Props {
  title?: string;
  description?: string;
  compact?: boolean;
  framed?: boolean;
  headingTag?: 'h1' | 'h2' | 'h3';
  headingId?: string;
  idPrefix?: string;
  eyebrow?: string;
  emailPlaceholder?: string;
  buttonLabel?: string;
  helperText?: string;
}

const {
  title = 'Get the newsletter',
  description = 'New stories when my brain produces them. Irregularly but enthusiastically.',
  compact = false,
  framed = true,
  headingTag = 'h1',
  headingId,
  idPrefix = 'newsletter',
  eyebrow = 'newsletter',
  emailPlaceholder = 'Email address',
  buttonLabel = 'subscribe',
  helperText,
} = Astro.props;

const kitFormAction = import.meta.env.PUBLIC_KIT_FORM_ACTION?.trim();
const hasKitForm = Boolean(kitFormAction);
const HeadingTag = headingTag;
const emailInputId = `${idPrefix}-email`;
const fallbackAction = hasKitForm ? kitFormAction : '#';
---

<section class:list={['newsletter-signup', compact && 'newsletter-signup--compact', !framed && 'newsletter-signup--plain']}>
  <div class="newsletter-copy">
    <span class="newsletter-kicker">{eyebrow}</span>
    <HeadingTag id={headingId}>{title}</HeadingTag>
    <p>{description}</p>
  </div>

  <div class="newsletter-form-wrap">
    <form
      class="newsletter-form"
      action={fallbackAction}
      method="post"
      novalidate
      data-newsletter-form
      data-configured={hasKitForm ? 'true' : 'false'}
    >
      <label class="sr-only" for={emailInputId}>Email address</label>
      <input
        id={emailInputId}
        type="email"
        name="email_address"
        autocomplete="email"
        inputmode="email"
        placeholder={emailPlaceholder}
        required
        aria-describedby={hasKitForm ? undefined : `${idPrefix}-dev-note`}
      />
      <button type="submit" disabled={!hasKitForm} aria-disabled={!hasKitForm}>
        {buttonLabel}
      </button>
    </form>

    {helperText && <p class="newsletter-helper">{helperText}</p>}
    {!hasKitForm && (
      <p class="newsletter-dev-note" id={`${idPrefix}-dev-note`}>
        Kit form action not configured yet.
      </p>
    )}
  </div>
</section>

<style>
.newsletter-signup {
  display: grid;
  gap: 1.5rem;
  padding: 2rem;
  border: 1px solid var(--border);
  border-radius: 24px;
  background: linear-gradient(180deg, var(--white) 0%, #fbfbfb 100%);
}

.newsletter-signup--compact {
  padding: 1.5rem;
}

.newsletter-signup--plain {
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

.newsletter-kicker {
  display: inline-block;
  margin-bottom: 0.75rem;
  padding: 0.25rem 0.8rem;
  border-radius: 999px;
  background: var(--teal-light);
  color: var(--teal-dark);
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.newsletter-copy h1 {
  font-size: 2.2rem;
  margin-bottom: 0.75rem;
}

.newsletter-signup--compact .newsletter-copy h1 {
  font-size: 1.3rem;
}

.newsletter-copy p {
  max-width: 34rem;
  color: var(--text-muted);
  margin-bottom: 0;
}

.newsletter-form-wrap {
  display: grid;
  gap: 0.7rem;
}

.newsletter-form {
  display: flex;
  gap: 0.85rem;
  align-items: center;
}

.newsletter-form input {
  flex: 1;
  min-width: 0;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.95);
  color: var(--text);
  padding: 0.95rem 1.15rem;
  font: inherit;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

.newsletter-form input::placeholder {
  color: var(--text-muted);
}

.newsletter-form input:focus,
.newsletter-form button:focus,
.newsletter-placeholder:focus {
  outline: 2px solid color-mix(in srgb, var(--purple) 40%, white);
  outline-offset: 2px;
}

.newsletter-form input:focus {
  border-color: rgba(129, 21, 211, 0.28);
  box-shadow:
    0 0 0 4px rgba(129, 21, 211, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.72);
}

.newsletter-form button {
  border: none;
  border-radius: 999px;
  background: var(--purple);
  color: var(--white);
  padding: 0.95rem 1.35rem;
  font: inherit;
  font-weight: 500;
  cursor: pointer;
  box-shadow: 0 10px 24px rgba(86, 14, 143, 0.2);
  transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
}

.newsletter-form button:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 14px 28px rgba(86, 14, 143, 0.24);
}

.newsletter-form button:disabled {
  cursor: not-allowed;
  opacity: 0.6;
  box-shadow: none;
}

.newsletter-helper {
  font-size: 0.85rem;
  line-height: 1.5;
  color: var(--text-muted);
  margin-bottom: 0;
}

.newsletter-dev-note {
  font-size: 0.72rem;
  line-height: 1.4;
  letter-spacing: 0.01em;
  color: rgba(26, 26, 26, 0.5);
  margin-bottom: 0;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

@media (max-width: 640px) {
  .newsletter-signup {
    padding: 1.5rem;
    border-radius: 20px;
  }

  .newsletter-copy h1,
  .newsletter-signup--compact .newsletter-copy h1 {
    font-size: 1.6rem;
  }

  .newsletter-form {
    flex-direction: column;
    align-items: stretch;
  }

  .newsletter-form button {
    width: 100%;
  }
}
</style>
